            <Component class="javax.swing.JTextPane" name="jTextPane1">
              <Properties>
                <Property name="editable" type="boolean" value="false"/>
                <Property name="contentType" type="java.lang.String" value="text/html" noResource="true"/>
                <Property name="text" type="java.lang.String" value="&lt;html&gt;&#xa;&lt;body style=&quot;font-family: Arial, sans-serif; padding: 15px; line-height: 1.5; color: #333333;&quot;&gt;&#xa;&#xa;    &lt;h2 style=&quot;text-align: center; color: #d35400;&quot;&gt;NH&#xd3;M TH&#x1ef0;C HI&#x1ec6;N B&#xc0;I T&#x1eac;P L&#x1eda;N&lt;/h2&gt;&#xa;    &lt;h3 style=&quot;text-align: center; color: #2980b9;&quot;&gt;M&#xf4;n: L&#x1ead;p tr&#xec;nh c&#xf4;ng ngh&#x1ec7; Java&lt;/h3&gt;&#xa;    &lt;h3 style=&quot;text-align: center; color: #c0392b;&quot;&gt;THI&#x1ebe;T K&#x1ebe; V&#xc0; X&#xc2;Y D&#x1ef0;NG M&#x1ed8;T T&#x1ef0;A GAME B&#x1ea4;T K&#xcc;&lt;/h3&gt;&#xa;    &lt;hr&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #27ae60;&quot;&gt;TH&#xc0;NH VI&#xca;N NH&#xd3;M&lt;/h3&gt;&#xa;    &lt;p&gt;&lt;b&gt;1. Nguy&#x1ec5;n Vi&#x1ec7;t Tu&#x1ea5;n&lt;/b&gt; (Nh&#xf3;m Tr&#x1b0;&#x1edf;ng) &#x2013; M&#xe3; SV: 243630613&lt;br&gt;&#xa;    &lt;i&gt;Nhi&#x1ec7;m v&#x1ee5;:&lt;/i&gt; Ph&#xe2;n c&#xf4;ng ch&#x1ec9; &#x111;&#x1ea1;o c&#xf4;ng vi&#x1ec7;c, x&#x1eed; l&#xfd; v&#xe0; thi&#x1ebf;t k&#x1ebf; c&#x1a1; s&#x1edf; d&#x1eef; li&#x1ec7;u.&lt;/p&gt;&#xa;&#xa;    &lt;p&gt;&lt;b&gt;2. T&#x1eeb; Ho&#xe0;ng Thanh&lt;/b&gt; &#x2013; M&#xe3; SV: 243630605&lt;br&gt;&#xa;    &lt;i&gt;Nhi&#x1ec7;m v&#x1ee5;:&lt;/i&gt; Ph&#xe2;n t&#xed;ch, thi&#x1ebf;t k&#x1ebf;, x&#x1eed; l&#xfd; c&#xe1;c thu&#x1ead;t to&#xe1;n v&#xe0; c&#xe1;ch th&#x1ee9;c ho&#x1ea1;t &#x111;&#x1ed9;ng cho tr&#xf2; ch&#x1a1;i.&lt;/p&gt;&#xa;&#xa;    &lt;p&gt;&lt;b&gt;3. L&#xf2; Ho&#xe0;ng H&#x1ea3;i&lt;/b&gt; &#x2013; M&#xe3; SV: 243630577&lt;br&gt;&#xa;    &lt;i&gt;Nhi&#x1ec7;m v&#x1ee5;:&lt;/i&gt; Thi&#x1ebf;t k&#x1ebf; giao di&#x1ec7;n v&#xe0; hi&#x1ec7;u &#x1ee9;ng cho tr&#xf2; ch&#x1a1;i.&lt;/p&gt;&#xa;&#xa;    &lt;p&gt;&lt;b&gt;4. Nguy&#x1ec5;n Ph&#x1b0;&#x1a1;ng Th&#x1ea3;o&lt;/b&gt; &#x2013; M&#xe3; SV: 243630607&lt;br&gt;&#xa;    &lt;i&gt;Nhi&#x1ec7;m v&#x1ee5;:&lt;/i&gt; Ph&#xe2;n t&#xed;ch, thu th&#x1ead;p v&#xe0; thi&#x1ebf;t k&#x1ebf; h&#xec;nh &#x1ea3;nh, vi&#x1ebf;t b&#xe0;i b&#xe1;o c&#xe1;o.&lt;/p&gt;&#xa;    &lt;hr&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #2980b9;&quot;&gt;TH&#xd4;NG TIN TR&#xd2; CH&#x1a0;I&lt;/h3&gt;&#xa;    &lt;p&gt;&lt;b&gt;T&#xea;n game:&lt;/b&gt; &lt;span style=&quot;color: #d35400; font-weight: bold;&quot;&gt;PIKACHU&apos;S ADVENTURE&lt;/span&gt;&lt;/p&gt;&#xa;    &lt;p&gt;&lt;b&gt;Th&#x1ec3; lo&#x1ea1;i:&lt;/b&gt; Gi&#x1ea3;i &#x111;&#x1ed1;, N&#x1ed1;i h&#xec;nh, Tr&#xed; nh&#x1edb;&lt;/p&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #2980b9;&quot;&gt;C&#x1ed0;T TRUY&#x1ec6;N&lt;/h3&gt;&#xa;    &lt;p&gt;B&#x1b0;&#x1edb;c ch&#xe2;n v&#xe0;o th&#x1ebf; gi&#x1edb;i Pok&#xe9;mon &#x111;&#x1ea7;y m&#xe0;u s&#x1eaf;c, huy&#x1ec1;n &#x1ea3;o v&#x1edb;i v&#xf4; v&#xe0;n ch&#xfa; Pok&#xe9;mon k&#xec; b&#xed; v&#xe0; th&#xfa; v&#x1ecb;. B&#x1ea1;n s&#x1ebd; h&#xf3;a th&#xe2;n th&#xe0;nh m&#x1ed9;t Nh&#xe0; hu&#x1ea5;n luy&#x1ec7;n t&#xe0;i ba, s&#x1eed; d&#x1ee5;ng nh&#xe3;n quan nh&#x1ea1;y b&#xe9;n v&#xe0; t&#x1b0; duy logic c&#x1ee7;a m&#xec;nh &#x111;&#x1ec3; t&#xec;m ki&#x1ebf;m, thu ph&#x1ee5;c c&#xe1;c ch&#xfa; Pok&#xe9;mon cho ri&#xea;ng m&#xec;nh.&lt;/p&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #2980b9;&quot;&gt;GAMEPLAY&lt;/h3&gt;&#xa;    &lt;ul&gt;&#xa;        &lt;li&gt;&lt;b&gt;Lu&#x1ead;t ch&#x1a1;i c&#x1ed1;t l&#xf5;i:&lt;/b&gt; Ng&#x1b0;&#x1edd;i ch&#x1a1;i c&#x1ea7;n t&#xec;m v&#xe0; n&#x1ed1;i hai h&#xec;nh &#x1ea3;nh Pok&#xe9;mon gi&#x1ed1;ng h&#x1ec7;t nhau b&#x1eb1;ng t&#x1ed1;i &#x111;a 3 &#x111;o&#x1ea1;n th&#x1eb3;ng kh&#xf4;ng b&#x1ecb; c&#x1ea3;n tr&#x1edf; b&#x1edf;i b&#x1ea5;t k&#x1ef3; kh&#x1ed1;i h&#xec;nh n&#xe0;o kh&#xe1;c.&lt;/li&gt;&#xa;        &lt;li&gt;&lt;b&gt;M&#x1ee5;c ti&#xea;u:&lt;/b&gt; X&#xf3;a s&#x1ea1;ch to&#xe0;n b&#x1ed9; Pok&#xe9;mon tr&#xea;n m&#xe0;n h&#xec;nh tr&#x1b0;&#x1edb;c khi thanh th&#x1edd;i gian c&#x1ea1;n ki&#x1ec7;t &#x111;&#x1ec3; v&#x1b0;&#x1ee3;t qua m&#xe0;n ch&#x1a1;i.&lt;/li&gt;&#xa;        &lt;li&gt;&lt;b&gt;Th&#x1eed; th&#xe1;ch:&lt;/b&gt; C&#xe0;ng l&#xea;n c&#x1ea5;p &#x111;&#x1ed9; cao, th&#x1edd;i gian &#x111;&#x1ebf;m ng&#x1b0;&#x1ee3;c c&#xe0;ng r&#xfa;t ng&#x1eaf;n. &#x110;&#x1eb7;c bi&#x1ec7;t, h&#x1ec7; th&#x1ed1;ng s&#x1ebd; t&#x1ef1; &#x111;&#x1ed9;ng x&#xe1;o tr&#x1ed9;n to&#xe0;n b&#x1ed9; b&#xe0;n c&#x1edd; khi kh&#xf4;ng c&#xf2;n n&#x1b0;&#x1edb;c &#x111;i h&#x1ee3;p l&#x1ec7;, &#x111;&#xf2;i h&#x1ecf;i b&#x1ea1;n ph&#x1ea3;i li&#xea;n t&#x1ee5;c thay &#x111;&#x1ed5;i chi&#x1ebf;n thu&#x1ead;t v&#xe0; t&#x1ed1;c &#x111;&#x1ed9; quan s&#xe1;t.&lt;/li&gt;&#xa;    &lt;/ul&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #2980b9;&quot;&gt;&#x110;I&#x1ec2;M N&#x1ed4;I B&#x1eac;T&lt;/h3&gt;&#xa;    &lt;ul&gt;&#xa;        &lt;li&gt;&lt;b&gt;Ho&#xe0;i ni&#x1ec7;m giao thoa hi&#x1ec7;n &#x111;&#x1ea1;i:&lt;/b&gt; Gi&#x1eef; tr&#x1ecd;n v&#x1eb9;n b&#x1ed9; s&#x1b0;u t&#x1ead;p h&#xec;nh &#x1ea3;nh Pok&#xe9;mon c&#x1ed5; &#x111;i&#x1ec3;n t&#x1eeb;ng l&#xe0;m say m&#xea; bao th&#x1ebf; h&#x1ec7;, nh&#x1b0;ng &#x111;&#x1b0;&#x1ee3;c v&#x1ead;n h&#xe0;nh tr&#xea;n m&#x1ed9;t n&#x1ec1;n t&#x1ea3;ng code t&#x1ed1;i &#x1b0;u h&#xf3;a, &#x111;&#x1ea3;m b&#x1ea3;o tr&#x1ea3;i nghi&#x1ec7;m thao t&#xe1;c c&#x1ef1;c k&#x1ef3; m&#x1b0;&#x1ee3;t m&#xe0; v&#xe0; kh&#xf4;ng gi&#x1ead;t lag.&lt;/li&gt;&#xa;        &lt;li&gt;&lt;b&gt;Th&#x1eed; th&#xe1;ch cam go:&lt;/b&gt; C&#xe1;c ch&#xfa; Pikachu tinh ngh&#x1ecb;ch r&#x1ea5;t th&#xed;ch t&#x1ea1;o d&#xe1;ng ch&#x1ee5;p &#x1ea3;nh v&#xe0; l&#x1ea9;n tr&#x1ed1;n sau nh&#x1eef;ng t&#x1ea5;m g&#x1b0;&#x1a1;ng, b&#x1ea1;n h&#xe3;y s&#x1eed; d&#x1ee5;ng nh&#xe3;n quan s&#x1eaf;c b&#xe9;n v&#xe0; tr&#xed; nh&#x1edb; si&#xea;u ph&#xe0;m c&#x1ee7;a m&#xec;nh &#x111;&#x1ec3; t&#xec;m ra nh&#x1eef;ng ch&#xfa; Pikachu tinh ngh&#x1ecb;ch nh&#xe9;.&lt;/li&gt;&#xa;        &lt;li&gt;&lt;b&gt;Thu&#x1ead;t to&#xe1;n th&#xf4;ng minh:&lt;/b&gt; Tr&#x1ea3;i nghi&#x1ec7;m ch&#x1a1;i li&#x1ec1;n m&#x1ea1;ch nh&#x1edd; h&#x1ec7; th&#x1ed1;ng t&#xec;m &#x111;&#x1b0;&#x1edd;ng ch&#xed;nh x&#xe1;c tuy&#x1ec7;t &#x111;&#x1ed1;i v&#xe0; thu&#x1ead;t to&#xe1;n t&#x1ea1;o m&#x1ea3;ng, x&#xe1;o tr&#x1ed9;n b&#x1ea3;ng ng&#x1eab;u nhi&#xea;n &#x111;&#x1ea7;y th&#xe1;ch th&#x1ee9;c.&lt;/li&gt;&#xa;        &lt;li&gt;&lt;b&gt;Giao di&#x1ec7;n tr&#x1ef1;c quan, gi&#x1ea3;i tr&#xed; nh&#x1eb9; nh&#xe0;ng:&lt;/b&gt; Ph&#xf9; h&#x1ee3;p v&#x1edb;i m&#x1ecd;i l&#x1ee9;a tu&#x1ed5;i, t&#x1eeb; vi&#x1ec7;c x&#x1ea3; stress nhanh sau gi&#x1edd; h&#x1ecd;c t&#x1ead;p, l&#xe0;m vi&#x1ec7;c c&#x103;ng th&#x1eb3;ng cho &#x111;&#x1ebf;n nh&#x1eef;ng cu&#x1ed9;c &#x111;ua &#x111;i&#x1ec3;m s&#x1ed1; c&#x103;ng n&#xe3;o.&lt;/li&gt;&#xa;    &lt;/ul&gt;&#xa;    &lt;hr&gt;&#xa;&#xa;    &lt;br&gt;&#xa;    &lt;p style=&quot;text-align: center; font-size: 14px; font-weight: bold; color: #2c3e50;&quot;&gt;B&#x1ea1;n &#x111;&#xe3; s&#x1eb5;n s&#xe0;ng ki&#x1ec3;m tra gi&#x1edb;i h&#x1ea1;n c&#x1ee7;a &#x111;&#xf4;i tay v&#xe0; &#xe1;nh m&#x1eaf;t?&lt;/p&gt;&#xa;    &lt;p style=&quot;text-align: center; font-size: 16px; font-weight: bold; color: #d35400;&quot;&gt;Nh&#x1ea5;n &quot;Ch&#x1a1;i Ngay&quot; &#x111;&#x1ec3; b&#x1eaf;t &#x111;&#x1ea7;u h&#xe0;nh tr&#xec;nh phi&#xea;u l&#x1b0;u c&#x1ee7;a ch&#xed;nh m&#xec;nh!&lt;/p&gt;&#xa;    &lt;br&gt;&#xa;&#xa;&lt;/body&gt;&#xa;&lt;/html&gt;"/>
              </Properties>
            </Component>
          </SubComponents>
        </Container>
      </SubComponents>
    </Container>
  </SubComponents>
</Form>
