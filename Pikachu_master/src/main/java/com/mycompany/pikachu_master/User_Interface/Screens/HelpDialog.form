      <SubComponents>
        <Component class="javax.swing.JTextPane" name="jTextPane1">
          <Properties>
            <Property name="contentType" type="java.lang.String" value="text/html" noResource="true"/>
            <Property name="text" type="java.lang.String" value="&lt;div style=&quot;font-family: &apos;Segoe UI&apos;, Arial, sans-serif; padding: 15px; color: #FFFFFF; line-height: 1.6;&quot;&gt;&#xa;    &lt;h2 style=&quot;color: #FFB347; text-align: center; text-transform: uppercase; text-shadow: 1px 1px 2px #000;&quot;&gt;H&#x1b0;&#x1edb;ng D&#x1eab;n Ch&#x1a1;i Pikachu&apos;s Adventure&lt;/h2&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #48D1CC; border-bottom: 1px solid #48D1CC; padding-bottom: 5px;&quot;&gt;1. M&#x1ee5;c Ti&#xea;u Tr&#xf2; Ch&#x1a1;i&lt;/h3&gt;&#xa;    &lt;p&gt;Ch&#xe0;o m&#x1eeb;ng b&#x1ea1;n &#x111;&#x1ebf;n v&#x1edb;i th&#x1ebf; gi&#x1edb;i c&#x1ee7;a &lt;b&gt;Pikachu Adventure&lt;/b&gt;! Nhi&#x1ec7;m v&#x1ee5; c&#x1ee7;a b&#x1ea1;n l&#xe0; d&#x1ecd;n s&#x1ea1;ch to&#xe0;n b&#x1ed9; c&#xe1;c h&#xec;nh Pokemon tr&#xea;n m&#xe0;n h&#xec;nh b&#x1eb1;ng c&#xe1;ch t&#xec;m ra c&#xe1;c c&#x1eb7;p &#x111;&#xf4;i gi&#x1ed1;ng nhau. H&#xe3;y th&#x1ead;t nhanh tay v&#xe0; tinh m&#x1eaf;t &#x111;&#x1ec3; ho&#xe0;n th&#xe0;nh m&#xe0;n ch&#x1a1;i tr&#x1b0;&#x1edb;c khi thanh th&#x1edd;i gian &#x111;&#x1ebf;m ng&#x1b0;&#x1ee3;c c&#x1ea1;n ki&#x1ec7;t.&lt;/p&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #48D1CC; border-bottom: 1px solid #48D1CC; padding-bottom: 5px;&quot;&gt;2. Quy T&#x1eaf;c K&#x1ebf;t N&#x1ed1;i (Lu&#x1ead;t Ch&#x1a1;i)&lt;/h3&gt;&#xa;    &lt;p&gt;B&#x1ea1;n ch&#x1ec9; c&#xf3; th&#x1ec3; lo&#x1ea1;i b&#x1ecf; &#x111;&#x1b0;&#x1ee3;c &lt;b style=&quot;color: #FFD700;&quot;&gt;2 th&#x1ebb; Pokemon ho&#xe0;n to&#xe0;n gi&#x1ed1;ng nhau&lt;/b&gt; n&#x1ebf;u &#x111;&#x1b0;&#x1edd;ng n&#x1ed1;i gi&#x1eef;a ch&#xfa;ng th&#x1ecf;a m&#xe3;n c&#xe1;c &#x111;i&#x1ec1;u ki&#x1ec7;n:&lt;/p&gt;&#xa;    &lt;ul style=&quot;color: #FFFFFF;&quot;&gt;&#xa;        &lt;li&gt;&lt;b&gt;&#x110;&#x1b0;&#x1edd;ng th&#x1eb3;ng (C&#x1ea1;nh nhau):&lt;/b&gt; Hai th&#x1ebb; n&#x1eb1;m s&#xe1;t nhau ho&#x1eb7;c tr&#xea;n c&#xf9;ng m&#x1ed9;t h&#xe0;ng ngang/d&#x1ecd;c m&#xe0; kh&#xf4;ng c&#xf3; th&#x1ebb; n&#xe0;o c&#x1ea3;n &#x1edf; gi&#x1eef;a.&lt;/li&gt;&#xa;        &lt;li&gt;&lt;b&gt;&#x110;&#x1b0;&#x1edd;ng ch&#x1eef; L (1 l&#x1ea7;n g&#x1ea5;p kh&#xfa;c):&lt;/b&gt; &#x110;&#x1b0;&#x1edd;ng n&#x1ed1;i r&#x1ebd; h&#x1b0;&#x1edb;ng 1 l&#x1ea7;n &#x111;&#x1ec3; ch&#x1ea1;m &#x111;&#x1ebf;n th&#x1ebb; kia.&lt;/li&gt;&#xa;        &lt;li&gt;&lt;b&gt;&#x110;&#x1b0;&#x1edd;ng ch&#x1eef; U ho&#x1eb7;c Z (2 l&#x1ea7;n g&#x1ea5;p kh&#xfa;c):&lt;/b&gt; &#x110;&#x1b0;&#x1edd;ng n&#x1ed1;i r&#x1ebd; h&#x1b0;&#x1edb;ng t&#x1ed1;i &#x111;a 2 l&#x1ea7;n (t&#x1ea1;o th&#xe0;nh t&#x1ed1;i &#x111;a 3 &#x111;o&#x1ea1;n th&#x1eb3;ng).&lt;/li&gt;&#xa;&#xa;    &lt;hr style=&quot;border: 0; border-top: 1px dashed #888888; margin: 5px 0 10px 0;&quot;&gt;&#xa;&#xa;    &lt;div style=&quot;font-size: 0.9em; color: #CCCCCC; text-align: center;&quot;&gt;&#xa;        &lt;p style=&quot;margin-bottom: 5px; color: #FFB347;&quot;&gt;\ud83c\udfae &lt;b&gt;D&#x1ef1; &#xe1;n Pikachu Adventure&lt;/b&gt;&lt;/p&gt;&#xa;        &lt;p style=&quot;margin: 3px 0;&quot;&gt;Tr&#x1b0;&#x1edf;ng nh&#xf3;m: &lt;b&gt;Nguy&#x1ec5;n Vi&#x1ec7;t Tu&#x1ea5;n&lt;/b&gt;&lt;/p&gt;&#xa;        &lt;p style=&quot;margin: 3px 0;&quot;&gt;Th&#xe0;nh vi&#xea;n: &lt;b&gt;T&#x1eeb; Ho&#xe0;ng Thanh, Nguy&#x1ec5;n Ph&#x1b0;&#x1a1;ng Th&#x1ea3;o, L&#xf2; H&#x1ea3;i Ho&#xe0;ng &lt;/b&gt;&lt;/p&gt;&#xa;&lt;/div&gt;&#xa;" containsInvalidXMLChars="true"/>
            <Property name="focusable" type="boolean" value="false"/>
            <Property name="opaque" type="boolean" value="false"/>
          </Properties>
        </Component>
      </SubComponents>
    </Container>
  </SubComponents>
