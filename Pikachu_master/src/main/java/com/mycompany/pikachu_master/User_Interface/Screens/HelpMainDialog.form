      <SubComponents>
        <Component class="javax.swing.JTextPane" name="jTextPane1">
          <Properties>
            <Property name="editable" type="boolean" value="false"/>
            <Property name="background" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="0" green="0" red="0" type="rgb"/>
            </Property>
            <Property name="contentType" type="java.lang.String" value="text/html" noResource="true"/>
            <Property name="text" type="java.lang.String" value="&lt;div style=&quot;font-family: Arial, sans-serif; padding: 10px; color: #FFFFFF;&quot;&gt;&#xa;    &lt;h2 style=&quot;color: #FFB347; text-align: center;&quot;&gt;H&#x1af;&#x1eda;NG D&#x1eaa;N CH&#x1a0;I PIKACHU&apos;S ADVENTURE&lt;/h2&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #48D1CC;&quot;&gt;\ud83c\udfaf M&#x1ee5;c ti&#xea;u tr&#xf2; ch&#x1a1;i&lt;/h3&gt;&#xa;    &lt;p&gt;Nhi&#x1ec7;m v&#x1ee5; c&#x1ee7;a b&#x1ea1;n l&#xe0; t&#xec;m v&#xe0; x&#xf3;a t&#x1ea5;t c&#x1ea3; c&#xe1;c th&#x1ebb; Pokemon tr&#xea;n m&#xe0;n h&#xec;nh tr&#x1b0;&#x1edb;c khi thanh th&#x1edd;i gian &#x111;&#x1ebf;m ng&#x1b0;&#x1ee3;c k&#x1ebf;t th&#xfa;c.&lt;/p&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #48D1CC;&quot;&gt;\ud83d\udcdc Lu&#x1ead;t ch&#x1a1;i c&#x1a1; b&#x1ea3;n&lt;/h3&gt;&#xa;    &lt;ul style=&quot;color: #FFFFFF;&quot;&gt;&#xa;        &lt;li&gt;B&#x1ea1;n ch&#x1ec9; c&#xf3; th&#x1ec3; gh&#xe9;p &lt;b style=&quot;color: #FFD700;&quot;&gt;2 th&#x1ebb; Pokemon ho&#xe0;n to&#xe0;n gi&#x1ed1;ng nhau&lt;/b&gt;.&lt;/li&gt;&#xa;        &lt;li&gt;Hai th&#x1ebb; n&#xe0;y ph&#x1ea3;i &#x111;&#x1b0;&#x1ee3;c n&#x1ed1;i v&#x1edb;i nhau b&#x1eb1;ng m&#x1ed9;t &#x111;&#x1b0;&#x1edd;ng g&#x1ea5;p kh&#xfa;c kh&#xf4;ng qu&#xe1; &lt;b style=&quot;color: #FFD700;&quot;&gt;3 &#x111;o&#x1ea1;n th&#x1eb3;ng&lt;/b&gt; (t&#x1b0;&#x1a1;ng &#x111;&#x1b0;&#x1a1;ng t&#x1ed1;i &#x111;a 2 l&#x1ea7;n r&#x1ebd; h&#x1b0;&#x1edb;ng).&lt;/li&gt;&#xa;        &lt;li&gt;&#x110;&#x1b0;&#x1edd;ng n&#x1ed1;i kh&#xf4;ng &#x111;&#x1b0;&#x1ee3;c &#x111;i xuy&#xea;n qua c&#xe1;c th&#x1ebb; Pokemon kh&#xe1;c &#x111;ang c&#xf3; tr&#xea;n m&#xe0;n h&#xec;nh.&lt;/li&gt;&#xa;    &lt;/ul&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #48D1CC;&quot;&gt;\ud83c\udfae C&#xe1;ch &#x111;i&#x1ec1;u khi&#x1ec3;n&lt;/h3&gt;&#xa;    &lt;p&gt;S&#x1eed; d&#x1ee5;ng &lt;b style=&quot;color: #FFD700;&quot;&gt;chu&#x1ed9;t tr&#xe1;i&lt;/b&gt; &#x111;&#x1ec3; ch&#x1ecd;n th&#x1ebb; Pokemon &#x111;&#x1ea7;u ti&#xea;n, sau &#x111;&#xf3; nh&#x1ea5;p v&#xe0;o th&#x1ebb; th&#x1ee9; hai gi&#x1ed1;ng h&#x1ec7;t n&#xf3;. N&#x1ebf;u &#x111;&#x1b0;&#x1edd;ng n&#x1ed1;i h&#x1ee3;p l&#x1ec7;, c&#x1ea3; hai th&#x1ebb; s&#x1ebd; bi&#x1ebf;n m&#x1ea5;t v&#xe0; b&#x1ea1;n s&#x1ebd; &#x111;&#x1b0;&#x1ee3;c c&#x1ed9;ng &#x111;i&#x1ec3;m!&lt;/p&gt;&#xa;&#xa;    &lt;h3 style=&quot;color: #48D1CC;&quot;&gt;\ud83d\udca1 M&#x1eb9;o nh&#x1ecf; cho b&#x1ea1;n&lt;/h3&gt;&#xa;    &lt;ul style=&quot;color: #FFFFFF;&quot;&gt;&#xa;        &lt;li&gt;H&#xe3;y &#x1b0;u ti&#xea;n t&#xec;m c&#xe1;c c&#x1eb7;p Pokemon n&#x1eb1;m &#x1edf; c&#xe1;c c&#x1ea1;nh ngo&#xe0;i c&#xf9;ng c&#x1ee7;a b&#x1ea3;ng, ch&#xfa;ng lu&#xf4;n d&#x1ec5; d&#xe0;ng k&#x1ebf;t n&#x1ed1;i nh&#x1ea5;t.&lt;/li&gt;&#xa;        &lt;li&gt;&#x110;&#x1eeb;ng qu&#xea;n &#x111;&#x1ec3; m&#x1eaf;t t&#x1edb;i th&#x1edd;i gian nh&#xe9;. Vi&#x1ec7;c n&#x1ed1;i li&#xea;n t&#x1ee5;c s&#x1ebd; gi&#xfa;p b&#x1ea1;n gi&#x1eef; &#x111;&#x1b0;&#x1ee3;c nh&#x1ecb;p &#x111;&#x1ed9; t&#x1ed1;t.&lt;/li&gt;&#xa;    &lt;/ul&gt;&#xa;   &lt;div style=&quot;font-size: 0.9em; color: #CCCCCC; text-align: center;&quot;&gt;&#xa;        &lt;p style=&quot;margin-bottom: 5px; color: #FFB347;&quot;&gt;\ud83c\udfae &lt;b&gt;D&#x1ef1; &#xe1;n Pikachu Adventure&lt;/b&gt;&lt;/p&gt;&#xa;        &lt;p style=&quot;margin: 3px 0;&quot;&gt;Tr&#x1b0;&#x1edf;ng nh&#xf3;m: &lt;b&gt;Nguy&#x1ec5;n Vi&#x1ec7;t Tu&#x1ea5;n&lt;/b&gt;&lt;/p&gt;&#xa;        &lt;p style=&quot;margin: 3px 0;&quot;&gt;Th&#xe0;nh vi&#xea;n: &lt;b&gt;T&#x1eeb; Ho&#xe0;ng Thanh, Nguy&#x1ec5;n Ph&#x1b0;&#x1a1;ng Th&#x1ea3;o, L&#xf2; H&#x1ea3;i Ho&#xe0;ng &lt;/b&gt;&lt;/p&gt;&#xa;    &lt;/div&gt;&#xa;&lt;/div&gt;" containsInvalidXMLChars="true"/>
            <Property name="focusable" type="boolean" value="false"/>
            <Property name="opaque" type="boolean" value="false"/>
          </Properties>
        </Component>
